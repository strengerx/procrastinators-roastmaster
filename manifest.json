{
    "manifest_version": 3,
    "name": "Procrastinator's Roastmaster",
    "version": "1.0",
    "description": "Tracks your procrastination and roasts you brutally.",
    "icons": {
        "48": "assets/icon.png"
    },
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*",
                "*://*.facebook.com/*",
                "*://*.twitter.com/*",
                "*://*.instagram.com/*",
                "*://*.tiktok.com/*",
                "*://*.reddit.com/*",
                "*://*.netflix.com/*",
                "*://*.twitch.tv/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "options_page": "options/options.html"
}